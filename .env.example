BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MANAGER_IDS=123456789,987654321
# Local SQLite (default for local development):
DATABASE_URL=sqlite+aiosqlite:///./construction_bot.db
# PostgreSQL for Heroku (Heroku sets this automatically via the heroku-postgresql addon;
# the app converts postgres:// → postgresql+asyncpg:// at startup):
# DATABASE_URL=postgres://user:password@host:5432/dbname
TIMEZONE=Asia/Tashkent
LOG_LEVEL=INFO
